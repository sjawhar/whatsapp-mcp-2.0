{
  "name": "whatsapp-mcp",
  "version": "1.0.0",
  "engines": { "node": ">=18.0.0" },
  "description": "WhatsApp MCP server built with Baileys",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "patch-package",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "import-contacts": "node dist/import-contacts.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "@whiskeysockets/baileys": "6.7.21",
    "better-sqlite3": "12.6.2",
    "node-cache": "5.1.2",
    "pino": "9.14.0",
    "qrcode-terminal": "0.12.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.19.11",
    "@vitest/coverage-v8": "4.1.1",
    "patch-package": "8.0.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.1"
  }
}
