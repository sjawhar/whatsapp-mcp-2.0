#!/bin/bash
# Wrapper to launch WhatsApp MCP daemon with API keys from sops secrets
set -euo pipefail

MISE="${DOTFILES_DIR:-$HOME/.dotfiles}/bin/mise"

# Load secrets from encrypted secrets.env via sops
SECRETS=$($MISE exec sops age -- \
    sops -d --output-type dotenv "$HOME/.dotfiles/secrets.env")

# Export WhatsApp MCP secrets
export MCP_API_KEY
MCP_API_KEY=$(echo "$SECRETS" | grep '^WHATSAPP_MCP_SECRET=' | cut -d= -f2-)

export WHISPER_API_URL
WHISPER_API_URL=$(echo "$SECRETS" | grep '^WHISPER_API_URL=' | cut -d= -f2- || true)

export WHISPER_API_KEY
WHISPER_API_KEY=$(echo "$SECRETS" | grep '^WHISPER_API_KEY=' | cut -d= -f2- || true)

# Launch the globally-installed whatsapp-mcp binary via mise exec
# (mise exec sets up Node PATH; the binary was installed via: npm install -g @sjawhar/whatsapp-mcp)
exec $MISE exec node -- whatsapp-mcp --http --port ${WHATSAPP_MCP_PORT:-3456}
